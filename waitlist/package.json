{
  "name": "@developerz-ai/designer-waitlist",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Double-opt-in waitlist backend for the designer landing (designer.developerz.ai). Self-hosted, Bun + Hono.",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
