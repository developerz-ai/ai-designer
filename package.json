{
  "name": "@developerz-ai/designer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension: chat with an agent, redesign the live page in real time, ship the real code via MCP.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developerz-ai/ai-designer.git"
  },
  "homepage": "https://github.com/developerz-ai/ai-designer#readme",
  "bugs": {
    "url": "https://github.com/developerz-ai/ai-designer/issues"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "release": "wxt build && wxt zip",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:unit": "vitest run unit",
    "test:integration": "vitest run integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^2.0.10",
    "@ai-sdk/openai-compatible": "^3.0.7",
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@sentry/browser": "^10.62.0",
    "ai": "^7.0.19",
    "solid-js": "^1.9.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.1.43",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@wxt-dev/module-solid": "^1.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "sass": "^1.83.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.0"
  }
}
